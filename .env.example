# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""

# Google Maps browser key for the frontend map. Configure the deployed origin
# in Google Cloud Console before public release.
GOOGLE_MAPS_PLATFORM_KEY=""
VITE_GOOGLE_MAPS_PLATFORM_KEY=""

# Local emulator-only browser tests. Keep false in normal development unless you
# are running `npm run test:e2e` or a local emulator suite.
VITE_CIVICLENS_USE_FIREBASE_EMULATORS="false"
VITE_FIREBASE_EMULATOR_HOST="127.0.0.1"
VITE_FIREBASE_AUTH_EMULATOR_PORT="9099"
VITE_FIRESTORE_EMULATOR_PORT="8080"
VITE_FIREBASE_STORAGE_EMULATOR_PORT="9199"

# Optional comma-separated real operator emails. Email allowlist entries require
# a verified Google/Firebase sign-in; production can also use custom claims.
CIVICLENS_OPERATOR_EMAILS=""

# Local development only: the browser sends X-CivicLens-Local-AppCheck-Bypass
# in Vite dev mode. The server refuses this bypass in production.
CIVICLENS_LOCAL_APP_CHECK_BYPASS="true"

# Enables the synthetic demo operator role. In production, set this deliberately
# only if public demo mutations should be allowed for isDemoData == true cases.
CIVICLENS_DEMO_OPERATOR_ENABLED="true"
