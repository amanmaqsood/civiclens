rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$'); }
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
    match /issues/{issueId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(issueId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'Submitted'
        && request.resource.data.citizenUpvotes is int
        && request.resource.data.citizenUpvotes >= 0
        && request.resource.data.citizenUpvotes <= 1000
        && request.resource.data.reportCount == 1
        && request.resource.data.keys().size() <= 35;
      allow update: if isSignedIn()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.ticketId == resource.data.ticketId;
      allow delete: if isSignedIn() && resource.data.isDemoData == true;
      match /evidence/{eid} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
      match /verifications/{userId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && userId == request.auth.uid;
        allow update, delete: if false;
      }
      match /activity/{aid} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }
  }
}
