{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --project demo-civiclens --only firestore,storage \"cross-env CIVICLENS_EMULATOR_TESTS=true vitest run src/emulator-rules.test.ts\"",
    "test:concurrency": "firebase emulators:exec --project demo-civiclens --only firestore \"cross-env CIVICLENS_EMULATOR_TESTS=true vitest run src/emulator-concurrency.test.ts\"",
    "test:e2e": "firebase emulators:exec --project demo-civiclens --only auth,firestore,storage \"playwright test\""
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vis.gl/react-google-maps": "^1.8.3",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "axe-core": "^4.12.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "firebase-tools": "^15.22.3",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
